# Vidimus D1 skeleton config

PORT=8787

# X Layer testnet (EVM chainId 1952, CAIP-2 eip155:1952).
# Fill in from https://web3.okx.com/xlayer/docs/developer/rpc-endpoints/rpc-endpoints
# (page is JS-rendered, open it in a browser) or your own RPC provider's X Layer testnet endpoint.
# Do NOT use a chainId-195 endpoint - that is the deprecated old testnet, not this one.
RPC_URL=

CHAIN_ID=1952

# Generated by `npm run create-wallets` - the settlement/facilitator key.
# Pays gas, submits Permit2 transfers on the buyer's behalf. Never commit this file.
FACILITATOR_PRIVATE_KEY=

# Same address as the facilitator key by default (spender == payTo for our exact+permit2 flow).
PAY_TO_ADDRESS=

# Filled in by `npm run deploy-test-token`.
PAYMENT_TOKEN_ADDRESS=

# Base tier price (PLATFORM.md L2/§4): 0.01 USDT-equivalent, 6 decimals -> 10000 atomic units.
PRICE_ATOMIC=10000

# Filled in after ASP registration (D1 step 7) - our ERC-8004 agent id and its bound address
# (agentWalletAddress from `onchainos agent get-my-agents`, not the facilitator/payTo address -
# they are different wallets: facilitator settles payments, this one is the ERC-8004 identity).
ERC8004_ID=
ERC8004_ADDRESS=

# D2: M2 criteria compiler calls the Claude API (Opus 4.8) to turn a spec string into
# tagged/tiered criteria. Never commit the real key.
ANTHROPIC_API_KEY=
