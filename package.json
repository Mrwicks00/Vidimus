{
  "name": "vidimus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bash scripts/render-start.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "create-wallets": "tsx scripts/create-wallets.ts",
    "deploy-test-token": "tsx scripts/deploy-test-token.ts",
    "deploy-test-nft": "tsx scripts/deploy-test-nft.ts",
    "test-buyer": "tsx scripts/test-buyer.ts",
    "verify-verdict": "tsx scripts/verify-verdict.ts",
    "probe-m2-bias": "tsx scripts/probe-m2-bias.ts",
    "spot-check-calibration": "tsx scripts/spot-check-calibration.ts",
    "prove-calibration-log": "tsx scripts/prove-calibration-log.ts",
    "sandbox:build": "docker build -t vidimus-sandbox-node:latest -f sandbox/node.Dockerfile sandbox"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.5",
    "hono": "^4.6.14",
    "ulid": "^2.3.0",
    "viem": "^2.21.54",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "solc": "^0.8.24",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
